{
  "title": "Nigel — Overview",
  "description": "Top-level health of the Nigel platform: webhook intake, run lifecycle, specialist execution, and cost. Imported via Datadog API; do not edit in the UI — round-trip through this file.\n\nWidgets querying numeric span attributes (durations, costs) use the `spans` data source (Trace Analytics) rather than `trace.<op>.<attr>` metrics, which Datadog does NOT auto-generate — APM only derives `.hits`, `.errors`, `.duration`, `.apdex`. Cost widgets filter to terminal transitions only because every status_change span carries the cumulative cost so far; summing across all transitions would multi-count.",
  "layout_type": "ordered",
  "widgets": [
    {
      "definition": {
        "title": "Webhook intake (last 1h)",
        "type": "query_value",
        "requests": [
          {
            "q": "sum:trace.webhook.linear.intake.hits{service:nigel-web}.as_count()",
            "aggregator": "sum"
          }
        ],
        "precision": 0
      }
    },
    {
      "definition": {
        "title": "Webhook intake by outcome",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.webhook.linear.intake.hits{service:nigel-web} by {nigel.webhook.outcome}.as_count()",
            "display_type": "bars"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Webhook errors by outcome",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.webhook.linear.intake.errors{service:nigel-web} by {nigel.webhook.outcome}.as_count()",
            "display_type": "bars"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Run status transitions",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.run.status_change.hits{service:nigel-web} by {nigel.run.status.to}.as_count()",
            "display_type": "bars"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Terminal run outcomes by trigger",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.run.status_change.hits{service:nigel-web,nigel.run.status.to:completed} by {nigel.run.trigger_source}.as_count()",
            "display_type": "bars",
            "style": { "palette": "green" }
          },
          {
            "q": "sum:trace.run.status_change.hits{service:nigel-web,nigel.run.status.to:failed} by {nigel.run.trigger_source}.as_count()",
            "display_type": "bars",
            "style": { "palette": "warm" }
          },
          {
            "q": "sum:trace.run.status_change.hits{service:nigel-web,nigel.run.status.to:cancelled} by {nigel.run.trigger_source}.as_count()",
            "display_type": "bars",
            "style": { "palette": "grey" }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Run duration p95 (ms) by trigger (terminal=completed)",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "duration",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:run.status_change @nigel.run.status.to:completed"
                },
                "compute": {
                  "aggregation": "pc95",
                  "metric": "@nigel.run.duration_ms"
                },
                "group_by": [
                  {
                    "facet": "@nigel.run.trigger_source",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "pc95" }
                  }
                ]
              }
            ],
            "response_format": "timeseries"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Cost ($) sum by trigger — terminal root runs only",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "cost",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:run.status_change @nigel.run.depth:0 @nigel.run.status.to:(completed OR failed OR cancelled)"
                },
                "compute": {
                  "aggregation": "sum",
                  "metric": "@nigel.run.cost_total_micros"
                },
                "group_by": [
                  {
                    "facet": "@nigel.run.trigger_source",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "sum" }
                  }
                ]
              }
            ],
            "response_format": "timeseries",
            "formulas": [{ "formula": "cost / 1000000", "alias": "$ USD" }]
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Specialist runs by name",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.specialist.execute.hits{service:nigel-web} by {nigel.specialist.name}.as_count()",
            "display_type": "bars"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Specialist duration p95 by name",
        "type": "timeseries",
        "requests": [
          {
            "q": "p95:trace.specialist.execute.duration{service:nigel-web} by {nigel.specialist.name}"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Tool failures by tool + code",
        "type": "timeseries",
        "requests": [
          {
            "q": "sum:trace.tool.errors{service:nigel-web} by {nigel.tool.name,nigel.tool.error_code}.as_count()",
            "display_type": "bars"
          }
        ]
      }
    }
  ]
}
