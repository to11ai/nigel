{
  "title": "Nigel — Overview",
  "description": "Top-level health of the Nigel platform: webhook intake, run lifecycle, specialist execution, and cost. Imported via Datadog API; do not edit in the UI — round-trip through this file.\n\nEVERY widget that groups by a custom span attribute (e.g. nigel.webhook.outcome, nigel.run.status.to, nigel.run.trigger_source) uses data_source: spans (Trace Analytics). Datadog's auto-derived trace.*.hits / .errors metrics only support standard tags — they cannot group by custom attributes. The numeric-attribute widgets (duration, cost) need spans data source for the same reason. The total-count widget at the top can still use trace.*.hits since it's not grouping.\n\nCost widgets filter to terminal transitions on root runs only because every status_change span carries the cumulative cost so far; summing across all transitions or all dispatched children would multi-count.",
  "layout_type": "ordered",
  "widgets": [
    {
      "definition": {
        "title": "Webhook intake (last 1h)",
        "type": "query_value",
        "requests": [
          {
            "q": "sum:trace.webhook.linear.intake.hits{service:nigel-web}.as_count()",
            "aggregator": "sum"
          }
        ],
        "precision": 0
      }
    },
    {
      "definition": {
        "title": "Webhook intake by outcome",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "intake",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:webhook.linear.intake"
                },
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@nigel.webhook.outcome",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "count" }
                  }
                ]
              }
            ],
            "response_format": "timeseries",
            "style": { "palette": "dog_classic" }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Webhook errors by outcome",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "errors",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:webhook.linear.intake status:error"
                },
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@nigel.webhook.outcome",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "count" }
                  }
                ]
              }
            ],
            "response_format": "timeseries",
            "style": { "palette": "warm" }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Run status transitions",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "transitions",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:run.status_change"
                },
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@nigel.run.status.to",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "count" }
                  }
                ]
              }
            ],
            "response_format": "timeseries",
            "style": { "palette": "dog_classic" }
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Terminal run outcomes by trigger",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "completed",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:run.status_change @nigel.run.status.to:completed"
                },
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@nigel.run.trigger_source",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "count" }
                  }
                ]
              },
              {
                "name": "failed",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:run.status_change @nigel.run.status.to:failed"
                },
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@nigel.run.trigger_source",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "count" }
                  }
                ]
              },
              {
                "name": "cancelled",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:run.status_change @nigel.run.status.to:cancelled"
                },
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@nigel.run.trigger_source",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "count" }
                  }
                ]
              }
            ],
            "response_format": "timeseries"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Run duration p95 (ms) by trigger (terminal=completed)",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "duration",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:run.status_change @nigel.run.status.to:completed"
                },
                "compute": {
                  "aggregation": "pc95",
                  "metric": "@nigel.run.duration_ms"
                },
                "group_by": [
                  {
                    "facet": "@nigel.run.trigger_source",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "pc95" }
                  }
                ]
              }
            ],
            "response_format": "timeseries"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Cost ($) sum by trigger — terminal root runs only",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "cost",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:run.status_change @nigel.run.depth:0 @nigel.run.status.to:(completed OR failed OR cancelled)"
                },
                "compute": {
                  "aggregation": "sum",
                  "metric": "@nigel.run.cost_total_micros"
                },
                "group_by": [
                  {
                    "facet": "@nigel.run.trigger_source",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "sum" }
                  }
                ]
              }
            ],
            "response_format": "timeseries",
            "formulas": [{ "formula": "cost / 1000000", "alias": "$ USD" }]
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Specialist runs by name",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "runs",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:specialist.execute"
                },
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@nigel.specialist.name",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "count" }
                  }
                ]
              }
            ],
            "response_format": "timeseries"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Specialist duration p95 by name",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "duration",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:specialist.execute"
                },
                "compute": { "aggregation": "pc95", "metric": "@duration" },
                "group_by": [
                  {
                    "facet": "@nigel.specialist.name",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "pc95" }
                  }
                ]
              }
            ],
            "response_format": "timeseries"
          }
        ]
      }
    },
    {
      "definition": {
        "title": "Tool failures by tool + code",
        "type": "timeseries",
        "requests": [
          {
            "queries": [
              {
                "name": "failures",
                "data_source": "spans",
                "search": {
                  "query": "service:nigel-web operation_name:(tool.database_query OR tool.clickhouse_query OR tool.redis_command OR tool.mcp_call OR tool.slack_post) status:error"
                },
                "compute": { "aggregation": "count" },
                "group_by": [
                  {
                    "facet": "@nigel.tool.name",
                    "limit": 10,
                    "sort": { "order": "desc", "aggregation": "count" }
                  },
                  { "facet": "@nigel.tool.error_code", "limit": 10 }
                ]
              }
            ],
            "response_format": "timeseries"
          }
        ]
      }
    }
  ]
}
