{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "apiKey.ts",
        "branch.ts",
        "config/index.ts",
        "config/vars.ts",
        "database.ts",
        "endpoint.ts",
        "getBranchEndpoints.ts",
        "getBranchRolePassword.ts",
        "getBranchRoles.ts",
        "getBranches.ts",
        "getProject.ts",
        "index.ts",
        "jwksUrl.ts",
        "orgApiKey.ts",
        "project.ts",
        "projectPermission.ts",
        "provider.ts",
        "role.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts",
        "vpcEndpointAssignment.ts",
        "vpcEndpointRestriction.ts"
    ]
}
