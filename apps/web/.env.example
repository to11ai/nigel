# Minimum runtime
# Vercel's Neon Marketplace integration provisions DATABASE_URL automatically
# (per-environment + per-preview-branch when branching is enabled). The legacy
# POSTGRES_URL is still read as a fallback for setups that don't use the
# integration.
DATABASE_URL=
BETTER_AUTH_SECRET=

# Encryption key for tool_connections.secrets_ciphertext.
# 32 bytes encoded as base64 (or base64url). Generate with:
#   openssl rand -base64 32
# Rotating this key invalidates every stored secret blob, so plan for a
# re-encrypt migration before changing it in an environment with data.
TOOL_CONNECTIONS_ENC_KEY=

# GitHub App (required for sign-in, repo access, pushes, and PRs)
# Callback URL: {YOUR_ORIGIN}/api/auth/callback/github (better-auth)
# Setup URL:    {YOUR_ORIGIN}/api/github/app/callback (installation sync)
# In the GitHub App settings:
#   1. Use the GitHub App Client ID and Client Secret below
#   2. Make the app public if you want org installs to work cleanly
#   3. Store the private key either as PEM contents with escaped newlines
#      or as a base64-encoded PEM
NEXT_PUBLIC_GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
NEXT_PUBLIC_GITHUB_APP_SLUG=
GITHUB_WEBHOOK_SECRET=

# Optional integrations
ELEVENLABS_API_KEY=

# Optional Redis / Vercel KV (skills metadata cache; falls back to in-memory when not set)
REDIS_URL=
KV_URL=

# Optional deployment refinements
# Set to "hobby" to use lower resource defaults for constrained deployments.
# Leave unset for standard behavior.
NIGEL_RESOURCE_PROFILE=

# Phase 1 — when set to "1" or "true", new chat sessions go through the
# Run abstraction (lib/runs/). Default unset = old code path.
NIGEL_ENABLE_RUNS=

# Restrict sign-in to active members of this GitHub org. Unset = no
# restriction (handy for local dev where you may not be a member).
NIGEL_ALLOWED_GITHUB_ORG=
VERCEL_PROJECT_PRODUCTION_URL=
NEXT_PUBLIC_VERCEL_PROJECT_PRODUCTION_URL=
# Optional base snapshot for fresh sandboxes. If unset, sandboxes use Vercel's standard Sandbox runtime.
# Use a snapshot created in/accessible to your own Vercel scope.
VERCEL_SANDBOX_BASE_SNAPSHOT_ID=

# OpenTelemetry export (Phase 7a). When the endpoint is unset, the SDK
# still runs locally for span context propagation but drops the export.
#
# This project's backend is Datadog. Standard pattern is to point the
# OTLP endpoint at the Datadog Agent's OTLP receiver (e.g.
# `http://datadog-agent.internal:4318`) and let the Agent forward to
# Datadog. The Datadog Vercel integration provisions the Agent for you.
#
#   OTEL_EXPORTER_OTLP_ENDPOINT: base URL of the OTLP HTTP receiver
#                                (do NOT include /v1/traces — the
#                                exporter suffixes it)
#   OTEL_EXPORTER_OTLP_HEADERS:  optional comma-separated key=value
#                                pairs (only if your receiver requires
#                                auth headers; the Datadog Agent does
#                                not by default).
#   OTEL_SERVICE_NAME            optional, defaults to "nigel-web"
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=
